---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Argy — Data Analyst & Data Scientist",
  description = "Portfolio of Argy, a Data Analyst and Data Scientist based in Jakarta/Bogor."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />

    <!-- ✅ GLOBAL scroll reveal — satu observer untuk semua section -->
    <script>
      function initReveal() {
        const els = document.querySelectorAll('[data-reveal]');
        if (els.length === 0) return;

        const obs = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const delay = parseInt(el.dataset.delay || '0');
              setTimeout(() => {
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
                el.classList.add('revealed');
              }, delay);
              obs.unobserve(el);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

        els.forEach(el => {
          const e = el as HTMLElement;
          // Set initial state via JS (lebih reliable dari CSS)
          e.style.opacity = '0';
          e.style.transform = 'translateY(22px)';
          e.style.transition = 'opacity 0.65s ease, transform 0.65s ease';
          obs.observe(e);
        });
      }

      // Jalankan setelah DOM ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initReveal);
      } else {
        initReveal();
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>