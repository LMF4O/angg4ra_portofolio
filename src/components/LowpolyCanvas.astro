<canvas id="lowpoly-canvas" class="absolute inset-0 w-full h-full"></canvas>

<script>
  const canvas = document.getElementById('lowpoly-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let mouse = { x: 0, y: 0 };
  let width: number, height: number;
  let points: {x: number, y: number, vx: number, vy: number, ox: number, oy: number}[] = [];

  const COLORS = ['#3B82F6', '#06B6D4', '#8B5CF6', '#1E2535', '#131720'];
  const GRID = 120; // jarak antar titik
  const DRIFT = 0.6; // seberapa jauh titik bisa bergerak
  const MOUSE_INFLUENCE = 80; // radius pengaruh mouse

  function resize() {
    width = canvas.width = canvas.offsetWidth;
    height = canvas.height = canvas.offsetHeight;
    initPoints();
  }

  function initPoints() {
    points = [];
    const cols = Math.ceil(width / GRID) + 2;
    const rows = Math.ceil(height / GRID) + 2;

    for (let r = -1; r <= rows; r++) {
      for (let c = -1; c <= cols; c++) {
        const x = c * GRID + (Math.random() - 0.5) * GRID * 0.5;
        const y = r * GRID + (Math.random() - 0.5) * GRID * 0.5;
        points.push({
          x, y,
          ox: x, oy: y,
          vx: (Math.random() - 0.5) * 0.3,
          vy: (Math.random() - 0.5) * 0.3,
        });
      }
    }
  }

  function getColor(centroidX: number, centroidY: number, i: number): string {
    // Warna berdasarkan posisi + index untuk variasi
    const t = (centroidX / width + centroidY / height) / 2;
    const colorIndex = Math.floor((t + i * 0.1) * COLORS.length) % COLORS.length;
    const baseColor = COLORS[colorIndex];
    // Opacity bervariasi
    const opacity = 0.04 + Math.random() * 0.08;
    return baseColor + Math.floor(opacity * 255).toString(16).padStart(2, '0');
  }

  function delaunayTriangles(pts: typeof points) {
    // Simple grid-based triangulation (lebih ringan dari full Delaunay)
    const triangles: [number, number, number][] = [];
    const cols = Math.ceil(width / GRID) + 2;

    for (let i = 0; i < pts.length - cols - 1; i++) {
      if ((i + 1) % cols === 0) continue;
      // Dua segitiga per grid cell
      triangles.push([i, i + 1, i + cols]);
      triangles.push([i + 1, i + cols + 1, i + cols]);
    }
    return triangles;
  }

  function animate() {
    ctx.clearRect(0, 0, width, height);

    // Update titik
    points.forEach(p => {
      // Drift slow
      p.x += p.vx;
      p.y += p.vy;

      // Balik ke origin kalau terlalu jauh
      const dx = p.ox - p.x;
      const dy = p.oy - p.y;
      if (Math.abs(dx) > DRIFT || Math.abs(dy) > DRIFT) {
        p.vx += dx * 0.01;
        p.vy += dy * 0.01;
      }

      // Damping
      p.vx *= 0.99;
      p.vy *= 0.99;

      // Mouse influence (gentle repel)
      const mdx = p.x - mouse.x;
      const mdy = p.y - mouse.y;
      const dist = Math.sqrt(mdx * mdx + mdy * mdy);
      if (dist < MOUSE_INFLUENCE) {
        const force = (MOUSE_INFLUENCE - dist) / MOUSE_INFLUENCE;
        p.vx += mdx * force * 0.02;
        p.vy += mdy * force * 0.02;
      }
    });

    // Draw triangles
    const triangles = delaunayTriangles(points);
    triangles.forEach(([a, b, c], i) => {
      if (!points[a] || !points[b] || !points[c]) return;
      const cx = (points[a].x + points[b].x + points[c].x) / 3;
      const cy = (points[a].y + points[b].y + points[c].y) / 3;

      ctx.beginPath();
      ctx.moveTo(points[a].x, points[a].y);
      ctx.lineTo(points[b].x, points[b].y);
      ctx.lineTo(points[c].x, points[c].y);
      ctx.closePath();

      ctx.fillStyle = getColor(cx, cy, i);
      ctx.fill();

      // Subtle edge lines
      ctx.strokeStyle = '#1E253520';
      ctx.lineWidth = 0.5;
      ctx.stroke();
    });

    requestAnimationFrame(animate);
  }

  // Mouse tracking
  window.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });

  window.addEventListener('resize', resize);
  resize();
  animate();
</script>