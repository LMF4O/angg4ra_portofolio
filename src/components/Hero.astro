---
import ParticleCanvas from './ParticleCanvas.astro';
---

<section id="hero" style="
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
">
  <ParticleCanvas />

  <!-- Vignette -->
  <div style="
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 20%, #0D0F14 85%);
  "></div>

  <!-- Bottom fade -->
  <div style="
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 120px; pointer-events: none;
    background: linear-gradient(to bottom, transparent, #0D0F14);
  "></div>

  <!-- Content wrapper -->
  <div style="
    position: relative; z-index: 10;
    width: 100%; max-width: 1152px;
    margin: 0 auto;
    padding: 112px 24px 80px;
  ">
    <!-- Flex row: text left, avatar right -->
    <div id="hero-inner" style="
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 64px;
      flex-wrap: wrap;
    ">

      <!-- ── LEFT: Text ── -->
      <div style="flex: 1; min-width: 280px; display: flex; flex-direction: column; gap: 24px;">

        <!-- Greeting -->
        <p class="hero-fadein" style="
          font-family: 'JetBrains Mono', monospace;
          font-size: 13px; color: #06B6D4;
          animation-delay: 0.2s;
        ">
          <span style="color:#64748B">$</span> hello, world —
        </p>

        <!-- Name -->
        <h1 class="hero-fadein" style="
          font-family: 'Space Grotesk', sans-serif;
          font-weight: 700;
          font-size: clamp(2.6rem, 6vw, 4.2rem);
          line-height: 1.1;
          color: #E2E8F0;
          animation-delay: 0.4s;
        ">
          I'm <span style="
            background: linear-gradient(135deg, #3B82F6, #06B6D4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
          ">Argy</span>
        </h1>

        <!-- Typewriter -->
        <p class="hero-fadein" style="
          font-family: 'JetBrains Mono', monospace;
          font-size: 17px; color: #94A3B8;
          animation-delay: 0.6s;
        ">
          <span style="color:#3B82F6">&gt;</span>&nbsp;<span id="typewriter" style="color:#E2E8F0"></span><span id="tw-cursor" style="color:#06B6D4">|</span>
        </p>

        <!-- Tagline -->
        <p class="hero-fadein" style="
          font-family: 'Inter', sans-serif;
          font-size: 16px; color: rgba(226,232,240,0.65);
          line-height: 1.7; max-width: 420px;
          animation-delay: 0.8s;
        ">
          Turning messy data into clear decisions —<br/>
          and teaching the next gen to do the same.
        </p>

        <!-- CTA Buttons -->
        <div class="hero-fadein" style="display:flex; flex-wrap:wrap; gap:16px; animation-delay:1.0s;">
          <a href="#projects" style="
            display: inline-block;
            padding: 12px 28px;
            background: #3B82F6;
            color: white;
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 600; font-size: 15px;
            border-radius: 10px;
            text-decoration: none;
            transition: all 0.3s ease;
          "
          onmouseover="this.style.background='#06B6D4'; this.style.boxShadow='0 0 24px rgba(6,182,212,0.45)'; this.style.transform='translateY(-2px)'"
          onmouseout="this.style.background='#3B82F6'; this.style.boxShadow='none'; this.style.transform='translateY(0)'"
          >View Projects</a>

          <a href="/cv.pdf" target="_blank" style="
            display: inline-block;
            padding: 12px 28px;
            border: 1px solid #1E2535;
            color: #64748B;
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 600; font-size: 15px;
            border-radius: 10px;
            text-decoration: none;
            transition: all 0.3s ease;
          "
          onmouseover="this.style.borderColor='#06B6D4'; this.style.color='#06B6D4'; this.style.transform='translateY(-2px)'"
          onmouseout="this.style.borderColor='#1E2535'; this.style.color='#64748B'; this.style.transform='translateY(0)'"
          >Download CV ↗</a>
        </div>

        <!-- Social links -->
        <div class="hero-fadein" style="display:flex; align-items:center; gap:20px; animation-delay:1.2s;">
          <!-- GitHub -->
          <a href="https://github.com/[username]" target="_blank" title="GitHub" class="soc-icon">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a href="https://linkedin.com/in/[username]" target="_blank" title="LinkedIn" class="soc-icon">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- Email -->
          <a href="mailto:argy@email.com" title="Email" class="soc-icon">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>

          <div style="width:40px; height:1px; background:#1E2535;"></div>
          <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#64748B;">Jakarta · Bogor</span>
        </div>
      </div>

      <!-- ── RIGHT: Avatar ── -->
      <div class="hero-fadein" style="
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        animation-delay: 0.5s;
      ">
        <div style="position:relative; width:260px; height:260px;">

          <!-- Glow -->
          <div style="
            position: absolute; inset: 0;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59,130,246,0.35) 0%, rgba(6,182,212,0.15) 50%, transparent 70%);
            transform: scale(1.4);
            filter: blur(20px);
            pointer-events: none;
          "></div>

          <!-- Clipped image container -->
          <div style="
            position: relative;
            width: 100%; height: 100%;
            clip-path: polygon(50% 0%,93% 25%,93% 75%,50% 100%,7% 75%,7% 25%);
            background: #131720;
            overflow: hidden;
          ">
            <img id="avatar-real"
              src="/images/avatar-real.jpg" alt="Argy"
              style="width:100%; height:100%; object-fit:cover; transition:opacity 0.3s;"
              onerror="this.style.display='none'"
            />
            <img id="avatar-illustrated"
              src="/images/avatar-illustrated.png" alt="Argy illustrated"
              style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:0; transition:opacity 0.3s;"
              onerror="this.style.display='none'"
            />
            <!-- Fallback letter -->
            <div id="avatar-fallback" style="
              position:absolute; inset:0;
              display:flex; align-items:center; justify-content:center;
              background: #131720;
            ">
              <span style="font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:80px; color:#3B82F6; user-select:none;">A</span>
            </div>
          </div>

          <!-- Hex border SVG -->
          <svg style="position:absolute; inset:0; width:100%; height:100%; pointer-events:none;" viewBox="0 0 200 200">
            <polygon points="100,3 189,52 189,148 100,197 11,148 11,52"
              fill="none" stroke="#3B82F6" stroke-width="1.5" opacity="0.8"/>
            <polygon points="100,3 189,52 189,148 100,197 11,148 11,52"
              fill="none" stroke="#06B6D4" stroke-width="0.5" opacity="0.3"
              transform="translate(100,100) scale(0.87) translate(-100,-100)"/>
          </svg>

          <!-- Photo toggle — above hex -->
          <button id="photo-toggle" style="
            position: absolute;
            top: -16px; left: 50%; transform: translateX(-50%);
            white-space: nowrap;
            background: #131720;
            border: 1px solid #1E2535;
            color: #64748B;
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            padding: 4px 12px;
            border-radius: 999px;
            cursor: pointer;
            z-index: 20;
            transition: border-color 0.2s, color 0.2s;
          "
          onmouseover="this.style.borderColor='#06B6D4'; this.style.color='#06B6D4'"
          onmouseout="this.style.borderColor='#1E2535'; this.style.color='#64748B'"
          >📸 real</button>

          <!-- Availability badge — below hex -->
          <div style="
            position: absolute;
            bottom: -20px; left: 50%; transform: translateX(-50%);
            white-space: nowrap;
            display: flex; align-items: center; gap: 8px;
            background: #131720;
            border: 1px solid #1E2535;
            padding: 6px 14px;
            border-radius: 999px;
            z-index: 20;
          ">
            <span id="avail-dot" style="
              width: 8px; height: 8px;
              border-radius: 50%;
              background: #10B981;
              display: inline-block;
              animation: pulse-dot 2s ease-in-out infinite;
            "></span>
            <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:#64748B;">open to work</span>
          </div>
        </div>
      </div>

    </div><!-- end hero-inner -->

    <!-- Scroll indicator -->
    <div class="hero-fadein" style="
      display:flex; flex-direction:column; align-items:center; gap:8px;
      margin-top: 80px;
      animation-delay: 1.8s;
    ">
      <span style="font-family:'JetBrains Mono',monospace; font-size:10px; color:#64748B; letter-spacing:0.15em;">scroll</span>
      <div id="scroll-line" style="width:1px; height:40px; background:linear-gradient(to bottom, #64748B66, transparent); animation: scroll-anim 2.2s ease-in-out infinite;"></div>
    </div>

  </div>
</section>

<style>
  .hero-fadein {
    opacity: 0;
    animation: hero-fade 0.7s ease forwards;
  }
  @keyframes hero-fade {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse-dot {
    0%,100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(0.8); }
  }
  @keyframes blink-cur {
    0%,100% { opacity: 1; } 50% { opacity: 0; }
  }
  @keyframes scroll-anim {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  #tw-cursor { animation: blink-cur 1.1s ease-in-out infinite; }

  .soc-icon {
    color: #64748B;
    display: flex;
    transition: color 0.2s, transform 0.2s;
  }
  .soc-icon:hover {
    color: #06B6D4;
    transform: translateY(-3px);
  }

  /* Mobile: stack vertically */
  @media (max-width: 768px) {
    #hero-inner {
      flex-direction: column-reverse !important;
      align-items: center !important;
      text-align: center;
    }
    #hero-inner > div:first-child {
      align-items: center;
    }
  }
</style>

<script>
  // Typewriter
  const roles = ['Data Analyst','Data Scientist','Coding Teacher','ML Enthusiast','Lifelong Learner'];
  let ri = 0, ci = 0, del = false;
  const tw = document.getElementById('typewriter')!;
  function type() {
    const w = roles[ri];
    tw.textContent = del ? w.slice(0,ci-1) : w.slice(0,ci+1);
    del ? ci-- : ci++;
    let d = del ? 55 : 105;
    if (!del && ci === w.length)  { d = 1800; del = true; }
    else if (del && ci === 0)     { del = false; ri = (ri+1)%roles.length; d = 400; }
    setTimeout(type, d);
  }
  setTimeout(type, 1000);

  // Photo toggle
  const realImg  = document.getElementById('avatar-real')         as HTMLImageElement;
  const illusImg = document.getElementById('avatar-illustrated')  as HTMLImageElement;
  const togBtn   = document.getElementById('photo-toggle')        as HTMLButtonElement;
  const fallback = document.getElementById('avatar-fallback')     as HTMLElement;

  // Hide fallback when image loads OK
  realImg?.addEventListener('load',  () => fallback.style.display = 'none');
  illusImg?.addEventListener('load', () => fallback.style.display = 'none');

  let isReal = localStorage.getItem('avatarStyle') !== 'illustrated';

  function applyAvatar() {
    if (realImg)  realImg.style.opacity  = isReal ? '1' : '0';
    if (illusImg) illusImg.style.opacity = isReal ? '0' : '1';
    if (togBtn)   togBtn.textContent     = isReal ? '📸 real' : '🎨 illustrated';
    localStorage.setItem('avatarStyle', isReal ? 'real' : 'illustrated');
    window.dispatchEvent(new CustomEvent('avatar-toggle', { detail: { isReal } }));
  }

  applyAvatar();
  togBtn?.addEventListener('click', () => { isReal = !isReal; applyAvatar(); });

  // Easter egg
  let buf = '';
  document.addEventListener('keydown', e => {
    buf = (buf + e.key.toLowerCase()).slice(-4);
    if (buf === 'argy') boom();
  });
  function boom() {
    const colors = ['#3B82F6','#06B6D4','#8B5CF6','#10B981','#F59E0B'];
    for (let i = 0; i < 90; i++) {
      const el = document.createElement('div');
      const s = 4 + Math.random() * 7;
      el.style.cssText = `position:fixed;pointer-events:none;z-index:9999;left:${Math.random()*100}vw;top:-12px;width:${s}px;height:${s}px;background:${colors[Math.floor(Math.random()*colors.length)]};border-radius:${Math.random()>.5?'50%':'3px'};animation:confetti-fall ${1.5+Math.random()*2}s ease forwards`;
      document.body.appendChild(el);
      setTimeout(()=>el.remove(),3500);
    }
    const toast = document.createElement('div');
    toast.style.cssText = `position:fixed;bottom:24px;right:24px;z-index:9999;background:#131720;border:1px solid #3B82F6;color:#E2E8F0;padding:16px 20px;border-radius:12px;font-family:'JetBrains Mono',monospace;font-size:13px;box-shadow:0 0 24px rgba(59,130,246,0.35);animation:toast-in 0.4s ease forwards`;
    toast.innerHTML = `hey, you found me. 👋<br><span style="color:#64748B">I debug with print() too.</span>`;
    document.body.appendChild(toast);
    setTimeout(()=>toast.remove(),4500);
  }
</script>