---
const stats = [
  { value: 10, label: 'Projects Built',   suffix: '+' },
  { value: 15, label: 'Tools Mastered',   suffix: '+' },
  { value: 6,  label: 'Semesters',        suffix: 'th' },
  { value: 30, label: 'Students Taught',  suffix: '+' },
];

const funFacts = [
  {
    front: { icon: '📊', text: 'Obsessed with clean dashboards' },
    back:  { icon: '😅', text: 'spent 3 hours fixing a misplaced semicolon once' },
  },
  {
    front: { icon: '👨‍🏫', text: 'Teaches kids to code' },
    back:  { icon: '💡', text: 'honestly, they teach me patience more than I teach them code' },
  },
  {
    front: { icon: '🎮', text: 'Roblox dev on weekends' },
    back:  { icon: '🤫', text: 'yes, Lua counts as a programming language' },
  },
  {
    front: { icon: '☕', text: 'Runs on coffee & curiosity' },
    back:  { icon: '🌙', text: 'peak productivity: 11pm. send help.' },
  },
];
---

<section id="about" style="position:relative; padding: 96px 0; overflow:hidden;">

  <!-- BG decorations -->
  <div style="position:absolute;top:0;right:0;width:384px;height:384px;background:radial-gradient(circle,rgba(59,130,246,0.06),transparent 70%);pointer-events:none;"></div>
  <div style="position:absolute;bottom:0;left:0;width:256px;height:256px;background:radial-gradient(circle,rgba(6,182,212,0.05),transparent 70%);pointer-events:none;"></div>

  <div style="max-width:1152px; margin:0 auto; padding:0 24px;">

    <!-- Section Header -->
    <div data-reveal style="display:flex; align-items:center; gap:16px; margin-bottom:64px;">
      <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#3B82F6;">01.</span>
      <h2 style="font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:clamp(1.6rem,4vw,2.25rem); color:#E2E8F0; white-space:nowrap;">About Me</h2>
      <div style="flex:1; height:1px; background:#1E2535;"></div>
    </div>

    <!-- Two-column grid -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start;">

      <!-- ── LEFT: Photo + Stats ── -->
      <div style="display:flex; flex-direction:column; gap:32px;">

        <!-- Photo card -->
        <div data-reveal data-delay="100" style="position:relative;">
          <div id="about-photo-wrap" style="
            position:relative;
            border-radius:16px;
            overflow:hidden;
            aspect-ratio:4/5;
            background:#131720;
            border:1px solid #1E2535;
          ">
            <img id="about-avatar-real"
              src="/images/avatar-real.webp" alt="Argy"
              style="width:100%;height:100%;object-fit:cover;transition:opacity 0.3s;"
              onerror="this.style.display='none'"
            />
            <img id="about-avatar-illustrated"
              src="/images/avatar-illustrated.webp" alt="Argy illustrated"
              style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity 0.3s;"
              onerror="this.style.display='none'"
            />
            <!-- Fallback -->
            <div id="about-avatar-fallback" style="
              position:absolute;inset:0;
              display:flex;align-items:center;justify-content:center;
              background:#131720;
            ">
              <span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:72px;color:#3B82F6;">A</span>
            </div>
            <!-- Bottom gradient -->
            <div style="position:absolute;bottom:0;left:0;right:0;height:80px;background:linear-gradient(to bottom,transparent,rgba(19,23,32,0.8));pointer-events:none;"></div>
            <!-- Toggle btn -->
            <button id="about-photo-toggle" style="
              position:absolute;bottom:12px;right:12px;
              background:rgba(19,23,32,0.9);
              border:1px solid #1E2535;
              color:#64748B;
              font-family:'JetBrains Mono',monospace;
              font-size:11px;
              padding:4px 10px;
              border-radius:999px;
              cursor:pointer;
              transition:border-color 0.2s,color 0.2s;
            "
            onmouseover="this.style.borderColor='#06B6D4';this.style.color='#06B6D4'"
            onmouseout="this.style.borderColor='#1E2535';this.style.color='#64748B'"
            >📸 real</button>
          </div>
          <!-- Geometric frame decorators -->
          <div style="position:absolute;inset:-10px;border:1px solid rgba(59,130,246,0.15);border-radius:18px;transform:rotate(2deg);pointer-events:none;transition:transform 0.5s;" class="geo-frame-1"></div>
          <div style="position:absolute;inset:-10px;border:1px solid rgba(6,182,212,0.08);border-radius:18px;transform:rotate(-1.5deg);pointer-events:none;transition:transform 0.5s;" class="geo-frame-2"></div>
        </div>

        <!-- Stat Counters -->
        <div data-reveal data-delay="200" style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          {stats.map((stat) => (
            <div style="
              background:#131720;
              border:1px solid #1E2535;
              border-radius:12px;
              padding:16px;
              transition:border-color 0.3s;
            "
            onmouseover="this.style.borderColor='rgba(59,130,246,0.5)'"
            onmouseout="this.style.borderColor='#1E2535'"
            >
              <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:22px;color:#3B82F6;display:flex;align-items:baseline;gap:2px;">
                <span class="counter" data-target={stat.value}>0</span>
                <span style="color:#06B6D4;font-size:18px;">{stat.suffix}</span>
              </div>
              <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#64748B;margin-top:4px;">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- ── RIGHT: Text + Currently + Flip Cards ── -->
      <div style="display:flex;flex-direction:column;gap:32px;">

        <!-- Bio -->
        <div data-reveal data-delay="150" style="display:flex;flex-direction:column;gap:16px;">
          <p style="font-family:'Inter',sans-serif;font-size:15px;color:rgba(226,232,240,0.8);line-height:1.75;">
            Hey — I'm Argy, an Information Systems student at Unindra who somehow ended up teaching kids to code at
            <span style="color:#06B6D4;font-weight:500;">DigiKidz Cibubur</span> while simultaneously trying to become a data scientist.
            Structured chaos, basically.
          </p>
          <p style="font-family:'Inter',sans-serif;font-size:15px;color:rgba(226,232,240,0.8);line-height:1.75;">
            I'm drawn to the intersection of <span style="color:#3B82F6;font-weight:500;">data, education, and technology</span> —
            building ML models by day, debugging students' Scratch projects by afternoon.
            My thesis is literally about predicting student performance, so yeah, data follows me everywhere.
          </p>
          <p style="font-family:'Inter',sans-serif;font-size:15px;color:rgba(226,232,240,0.8);line-height:1.75;">
            As an <span style="color:#8B5CF6;font-weight:500;">INTP</span>, I overthink problems until they're elegant solutions.
            I prefer async communication, clean pipelines, and dashboards that actually make sense.
            If you've read this far — we'd probably get along.
          </p>
        </div>

        <!-- Currently -->
        <div data-reveal data-delay="250" style="
          background:#131720;
          border:1px solid #1E2535;
          border-radius:12px;
          padding:20px;
          display:flex;
          flex-direction:column;
          gap:12px;
        ">
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#3B82F6;">// currently</div>
          <div style="display:flex;flex-direction:column;gap:10px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <span style="width:6px;height:6px;border-radius:50%;background:#10B981;flex-shrink:0;animation:pulse-dot 2s infinite;"></span>
              <span style="font-family:'Inter',sans-serif;font-size:13px;color:rgba(226,232,240,0.7);">Building thesis: DigiKidz student analytics system</span>
            </div>
            <div style="display:flex;align-items:center;gap:12px;">
              <span style="width:6px;height:6px;border-radius:50%;background:#3B82F6;flex-shrink:0;animation:pulse-dot 2s infinite 0.4s;"></span>
              <span style="font-family:'Inter',sans-serif;font-size:13px;color:rgba(226,232,240,0.7);">Learning: SHAP explainability & MLflow</span>
            </div>
            <div style="display:flex;align-items:center;gap:12px;">
              <span style="width:6px;height:6px;border-radius:50%;background:#8B5CF6;flex-shrink:0;animation:pulse-dot 2s infinite 0.8s;"></span>
              <span style="font-family:'Inter',sans-serif;font-size:13px;color:rgba(226,232,240,0.7);">Teaching: Scratch & Python basics @ DigiKidz</span>
            </div>
          </div>
        </div>

        <!-- Fun Facts -->
        <div data-reveal data-delay="320">
          <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#64748B;margin-bottom:12px;">// hover or tap to flip</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            {funFacts.map((fact) => (
              <div class="flip-card" tabindex="0" role="button" style="height:96px;cursor:pointer;">
                <div class="flip-card-inner">
                  <div class="flip-card-front" style="
                    position:absolute;inset:0;
                    background:#131720;
                    border:1px solid #1E2535;
                    border-radius:12px;
                    display:flex;flex-direction:column;
                    align-items:center;justify-content:center;
                    gap:8px;text-align:center;padding:12px;
                    backface-visibility:hidden;
                    -webkit-backface-visibility:hidden;
                  ">
                    <span style="font-size:22px;">{fact.front.icon}</span>
                    <span style="font-family:'Inter',sans-serif;font-size:11px;color:#64748B;line-height:1.4;">{fact.front.text}</span>
                  </div>
                  <div class="flip-card-back" style="
                    position:absolute;inset:0;
                    background:#131720;
                    border:1px solid rgba(6,182,212,0.3);
                    border-radius:12px;
                    display:flex;flex-direction:column;
                    align-items:center;justify-content:center;
                    gap:8px;text-align:center;padding:12px;
                    backface-visibility:hidden;
                    -webkit-backface-visibility:hidden;
                    transform:rotateY(180deg);
                  ">
                    <span style="font-size:22px;">{fact.back.icon}</span>
                    <span style="font-family:'Inter',sans-serif;font-size:11px;color:rgba(6,182,212,0.8);line-height:1.4;font-style:italic;">"{fact.back.text}"</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Mobile responsive override -->
<style>
  @media (max-width: 768px) {
    #about > div > div:last-child {
      grid-template-columns: 1fr !important;
    }
  }

  /* Flip card */
  .flip-card { perspective: 1000px; }
  .flip-card-inner {
    position: relative;
    width: 100%; height: 100%;
    transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
    transform-style: preserve-3d;
  }
  .flip-card:hover .flip-card-inner,
  .flip-card:focus .flip-card-inner,
  .flip-card.flipped .flip-card-inner {
    transform: rotateY(180deg);
  }

  /* Pulse animation for currently dots */
  @keyframes pulse-dot {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:0.5; transform:scale(0.75); }
  }

  /* Geo frame hover */
  #about-photo-wrap:hover ~ .geo-frame-1 { transform: rotate(5deg) !important; }
  #about-photo-wrap:hover ~ .geo-frame-2 { transform: rotate(-3deg) !important; }
</style>

<script>
  // ── Hide fallback when image loads ──
  const realImg  = document.getElementById('about-avatar-real')        as HTMLImageElement;
  const illusImg = document.getElementById('about-avatar-illustrated') as HTMLImageElement;
  const fallback = document.getElementById('about-avatar-fallback')    as HTMLElement;

  function hideFallback() { if (fallback) fallback.style.display = 'none'; }
  realImg?.addEventListener('load', hideFallback);
  illusImg?.addEventListener('load', hideFallback);
  if (realImg?.complete && realImg.naturalWidth > 0) hideFallback();

  // ── Stat Counter ──
  const counters = document.querySelectorAll('.counter');
  const cObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      let cur = 0;
      const step = Math.ceil(target / 40);
      const t = setInterval(() => {
        cur = Math.min(cur + step, target);
        el.textContent = cur.toString();
        if (cur >= target) clearInterval(t);
      }, 40);
      cObs.unobserve(el);
    });
  }, { threshold: 0.5 });
  counters.forEach(el => cObs.observe(el));

  // ── Photo Toggle (sync with Hero via event) ──
  const aboutReal  = document.getElementById('about-avatar-real')        as HTMLImageElement;
  const aboutIllus = document.getElementById('about-avatar-illustrated') as HTMLImageElement;
  const aboutBtn   = document.getElementById('about-photo-toggle')       as HTMLButtonElement;

  function syncAbout(isReal: boolean) {
    if (aboutReal)  aboutReal.style.opacity  = isReal ? '1' : '0';
    if (aboutIllus) aboutIllus.style.opacity = isReal ? '0' : '1';
    if (aboutBtn)   aboutBtn.textContent     = isReal ? '📸 real' : '🎨 illustrated';
  }

  syncAbout(localStorage.getItem('avatarStyle') !== 'illustrated');

  window.addEventListener('avatar-toggle', (e) => {
    syncAbout((e as CustomEvent).detail.isReal);
  });

  aboutBtn?.addEventListener('click', () => {
    const current = localStorage.getItem('avatarStyle') !== 'illustrated';
    const next = !current;
    localStorage.setItem('avatarStyle', next ? 'real' : 'illustrated');
    syncAbout(next);
    window.dispatchEvent(new CustomEvent('avatar-toggle', { detail: { isReal: next } }));
  });

  // ── Flip card keyboard ──
  document.querySelectorAll('.flip-card').forEach(card => {
    card.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        card.classList.toggle('flipped');
      }
    });
  });
</script>