<canvas id="particle-canvas" class="absolute inset-0 w-full h-full"></canvas>

<script>
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let W: number, H: number;
  let mouse = { x: -999, y: -999 };

  // ── Particle config ──
  const PARTICLE_COUNT = 120;
  const MAX_CONNECT_DIST = 140;
  const MOUSE_REPEL_DIST = 100;

  interface Particle {
    x: number; y: number;
    vx: number; vy: number;
    r: number;
    alpha: number;
    color: string;
  }

  const COLORS = ['#3B82F6', '#06B6D4', '#8B5CF6', '#ffffff'];
  let particles: Particle[] = [];

  function resize() {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
  }

  function init() {
    particles = Array.from({ length: PARTICLE_COUNT }, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.35,
      vy: (Math.random() - 0.5) * 0.35,
      r: Math.random() * 1.8 + 0.4,
      alpha: Math.random() * 0.6 + 0.2,
      color: COLORS[Math.floor(Math.random() * COLORS.length)],
    }));
  }

  function hexToRgb(hex: string) {
    const r = parseInt(hex.slice(1,3),16);
    const g = parseInt(hex.slice(3,5),16);
    const b = parseInt(hex.slice(5,7),16);
    return `${r},${g},${b}`;
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Update & draw particles
    for (const p of particles) {
      // Move
      p.x += p.vx;
      p.y += p.vy;

      // Wrap edges
      if (p.x < 0)  p.x = W;
      if (p.x > W)  p.x = 0;
      if (p.y < 0)  p.y = H;
      if (p.y > H)  p.y = 0;

      // Mouse repel
      const dx = p.x - mouse.x;
      const dy = p.y - mouse.y;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < MOUSE_REPEL_DIST) {
        const force = (MOUSE_REPEL_DIST - dist) / MOUSE_REPEL_DIST;
        p.vx += dx * force * 0.015;
        p.vy += dy * force * 0.015;
      }

      // Speed limit
      const speed = Math.sqrt(p.vx*p.vx + p.vy*p.vy);
      if (speed > 1.2) { p.vx *= 0.98; p.vy *= 0.98; }

      // Draw star dot
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${hexToRgb(p.color === '#ffffff' ? '#ffffff' : p.color)},${p.alpha})`;
      ctx.fill();
    }

    // Draw constellation lines
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const a = particles[i], b = particles[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist < MAX_CONNECT_DIST) {
          const alpha = (1 - dist / MAX_CONNECT_DIST) * 0.18;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = `rgba(59,130,246,${alpha})`;
          ctx.lineWidth = 0.6;
          ctx.stroke();
        }
      }
    }

    requestAnimationFrame(draw);
  }

  window.addEventListener('mousemove', e => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });

  window.addEventListener('mouseleave', () => {
    mouse = { x: -999, y: -999 };
  });

  window.addEventListener('resize', () => { resize(); init(); });

  resize();
  init();
  draw();
</script>